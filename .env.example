DB_HOST=localhost
DB_PORT=5432
DB_NAME=guardioes_da_lei
DB_USER=postgres
DB_PASSWORD=postgres
FLASK_APP=src/backend/app.py
FLASK_ENV=development
SECRET_KEY=troque-por-uma-chave-secreta-longa-e-aleatoria

# Chave da API do Google Gemini para categorização automática
GOOGLE_API_KEY=

# Intervalo de sincronização automática com a API da Câmara (em minutos, padrão: 60)
CAMARA_SYNC_INTERVAL_MINUTES=60

# Limite de requisições por minuto ao Gemini (padrão: 15)
GEMINI_RATE_LIMIT_RPM=15

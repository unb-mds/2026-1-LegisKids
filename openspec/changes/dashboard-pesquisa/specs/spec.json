  "assets": {
    "logo": {
      "type": "svg",
      "description": "Escudo azul e verde com balança da justiça no centro."
    },

    "icons": [
      {
        "name": "search",
        "description": "Lupa outline com stroke 2px."
      },

      {
        "name": "notification",
        "description": "Sino outline minimalista."
      },

      {
        "name": "settings",
        "description": "Engrenagem outline."
      },

      {
        "name": "analytics",
        "description": "Gráfico de barras verticais."
      },

      {
        "name": "projects",
        "description": "Documento com linhas internas."
      },

      {
        "name": "warning",
        "description": "Triângulo outline com exclamação."
      },

      {
        "name": "calendar",
        "description": "Calendário outline minimalista."
      },

      {
        "name": "institution",
        "description": "Ícone de prédio governamental outline."
      },

      {
        "name": "paginationArrow",
        "description": "Chevron lateral com stroke grosso."
      }
    ]
  }
}
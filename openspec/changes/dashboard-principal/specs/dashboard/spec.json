    "quickActions": [
      {
        "title": "Participação Pública",

        "description": "Contribua com consultas públicas abertas",

        "icon": "community"
      },

      {
        "title": "Análises e Relatórios",

        "description": "Acesse métricas e indicadores legislativos",

        "icon": "chart"
      },

      {
        "title": "Configurar Alertas",

        "description": "Receba notificações sobre temas relevantes",

        "icon": "settings"
      }
    ]
  },

  "footer": {
    "background": "#2447D5",

    "text": "© 2026 LegisKids - Proteção Infantil Digital",

    "links": [
      "Sobre",
      "Contato",
      "Privacidade"
    ]
  },

  "responsive": {
    "mobile": {
      "navbarCollapse": true,
      "statsColumns": 2,
      "cardsColumns": 1
    },

    "tablet": {
      "statsColumns": 2,
      "cardsColumns": 2
    },

    "desktop": {
      "statsColumns": 4,
      "cardsColumns": 4
    }
  },

  "animations": {
    "hoverCards": true,
    "smoothTransitions": true,
    "buttonHoverScale": 1.03,
    "transitionTime": "0.2s"
  },

  "frontendGuidelines": {
    "objective": "Reproduzir fielmente o protótipo do Figma utilizando HTML, CSS e JavaScript puro inicialmente.",

    "designStyle": {
      "visual": "Moderno, institucional e limpo",

      "inspiration": [
        "Dashboards governamentais",
        "Sistemas de monitoramento",
        "Plataformas analíticas"
      ]
    },

    "componentPattern": [
      "navbar",
      "stats-card",
      "alert-banner",
      "search-bar",
      "project-card",
      "quick-action-card",
      "footer"
    ],

    "recommendedStructure": {
      "pages": [
        "index.html",
        "projetos.html",
        "alertas.html",
        "analises.html"
      ],

      "css": [
        "style.css",
        "components.css",
        "responsive.css"
      ],

      "js": [
        "script.js",
        "components.js",
        "dashboard.js"
      ],

      "assets": {
        "images": [
          "logo-legiskids.png"
        ],

        "icons": [
          "projetos-logo.png",
          "alertas-logo.png",
          "analises-logo.png",
          "configuracoes.png",
          "notificacoes.png"
        ]
      }
    }
  }
}
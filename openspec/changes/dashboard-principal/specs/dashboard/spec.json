{
  "project": {
    "name": "LegisKids",
    "subtitle": "Proteção de Crianças na Internet",
    "type": "Dashboard Legislativo",
    "logo": {
      "image": "assets/images/logo-legiskids.png",
      "alt": "Logo LegisKids",
      "width": "190px",
      "height": "auto"
    },

    "theme": {
      "primaryColor": "#2447D5",
      "primaryDark": "#0C2577",
      "primaryLight": "#3D6BFF",

      "secondaryColor": "#F3F5FA",
      "backgroundColor": "#DDE2EB",
      "cardColor": "#FFFFFF",

      "textPrimary": "#1E1E1E",
      "textSecondary": "#7A7A7A",

      "successColor": "#A7E8B4",
      "warningColor": "#F7D9A8",
      "dangerColor": "#F6A6A6",
      "purpleColor": "#D9B3F5",

      "borderRadius": "14px",
      "shadow": "0px 2px 8px rgba(0,0,0,0.08)"
    }
  },

  "layout": {
    "width": "100%",
    "maxWidth": "1440px",
    "paddingHorizontal": "20px",
    "paddingVertical": "16px",
    "gapSections": "24px",
    "fontFamily": "Inter"
  },

  "navbar": {
    "height": "72px",
    "background": "#2447D5",

    "logoSection": {
      "enabled": true,

      "logo": {
        "src": "assets/images/logo-legiskids.png",
        "alt": "Logo LegisKids",
        "width": "180px"
      },

      "texts": {
        "title": "LegisKids",
        "subtitle": "Proteção Infantil Digital"
      }
    },

    "menu": [
      {
        "name": "Projetos",
        "icon": "assets/icons/projetos-logo.png",
        "active": false
      },
      {
        "name": "Alertas",
        "icon": "assets/icons/alertas-logo.png",
        "active": false
      },
      {
        "name": "Análises",
        "icon": "assets/icons/analises-logo.png",
        "active": false
      }
    ],

    "actions": [
      {
        "icon": "assets/icons/configuracoes.png",
        "type": "settings"
      },
      {
        "icon": "assets/icons/notificacoes.png",
        "type": "notifications"
      }
    ]
  },

  "dashboard": {
    "title": "Dashboard de Monitoramento",

    "description": "Acompanhamento de proposições relacionadas à proteção infantil digital.",

    "statsCards": [
